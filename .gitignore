# .gitignore for Bootstreep Homelab
# Secrets and configs
.env
*.env.local
secrets/

# OS
.DS_Store
Thumbs.db

# Logs
logs/*.log
*.log

# Backups
backups/
*.tar.gz
*.tar.bz2

# Docker
**/volumes/

# IDE
.vscode/
.idea/
*.swp

# Build artifacts
node_modules/
__pycache__/
*.pyc

# Local overrides
bootstrap/config/*.local.env

# Docker compose overrides (use base + override pattern)
**/docker-compose.override.yml