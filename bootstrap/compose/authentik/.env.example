# Authentik SSO Configuration
DOMAIN=homelab.example.com
# Generate secret key with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=change...n
# PostgreSQL database
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=change...n
POSTGRES_HOST=authentik-postgresql
# Email (for user invites)
[email protected]
AUTHENTIK_EMAIL__PASSWORD=...
