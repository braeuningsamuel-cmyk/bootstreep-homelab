# Bootstreep Bootstrap Configuration
# Adjust these values before running bootstrap.sh

# Timezone
TZ=Europe/Berlin

# Domain
DOMAIN=homelab.example.com
EMAIL=admin@example.com

# Cloudflare (for DNS challenge)
CLOUDFLARE_EMAIL=admin@example.com
CLOUDFLARE_API_KEY=changeme

# Tailscale
TAILSCALE_AUTHKEY=tskey-changeme