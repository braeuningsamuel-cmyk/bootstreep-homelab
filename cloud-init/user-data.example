#cloud-config
# Bootstreep Homelab – Cloud-Init user-data
#
# Dieses cloud-init Skript richtet einen frischen Ubuntu 24.04 Server
# vollautomatisch ein: Benutzer anlegen, SSH-Key hinterlegen,
# Repository klonen und bootstrap.sh ausführen.
#
# Nutzung:
# 1. Diesen Datei anpassen (username, SSH-Key, Repo-URL)
# 2. Als "user-data" bei der VM-Installation angeben (Proxmox, libvirt, etc.)
# 3. Server einschalten – der Rest passiert automatisch

# Benutzer anlegen
users:
  - name: admin
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3... dein-ssh-public-key

# Paketquellen aktualisieren und Upgrade durchführen
package_update: true
package_upgrade: true
packages:
  - git
  - curl

# bootstrap.sh ausführen
runcmd:
  - git clone https://github.com/braeuningsamuel-cmyk/bootstreep-homelab.git /opt/bootstreep-homelab
  - cd /opt/bootstreep-homelab && chmod +x bootstrap.sh && ./bootstrap.sh
