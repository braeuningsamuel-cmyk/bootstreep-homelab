# Bootstreep Homelab v4.1.1 – Umgebungsvariablen
# Kopiere nach ~/docker/.env und trage Werte ein
# Pflichtfelder mit `:?`-Syntax müssen gesetzt werden!

# ─── Passwords & Secrets ───────────────────────────────────────────────
PIHOLE_PASS=
OPEN_WEBUI_SECRET=
VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_SIGNUPS=true
VAULTWARDEN_DOMAIN=https://vault.example.com
CHROMA_API_KEY=
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
AUTHENTIK_SECRET_KEY=
AUTHENTIK_POSTGRES_PASSWORD=
CROWDSEC_API_KEY=
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=
RCON_PASSWORD=
SERVER_PASS=

# ─── SMTP (E-Mail-Versand) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=

# ─── Watchtower ────────────────────────────────────────────────────────
WATCHTOWER_NOTIFICATIONS=

# ─── System ────────────────────────────────────────────────────────────
TIMEZONE=Europe/Berlin
