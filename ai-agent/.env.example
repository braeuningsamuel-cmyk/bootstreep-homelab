# AI-Agent Konfiguration (v4.0.0)
# Kopiere nach ~/ai-agent/.env und trage Werte ein

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ALLOWED_CHAT_IDS=123456789,987654321

HOMELAB_HOST=homelab
HOMELAB_USER=admin

# Lokale KI via LiteLLM (OpenAI-kompatibel)
LITELLM_URL=http://127.0.0.1:4000
LITELLM_API_KEY=sk-bootstreep
LITELLM_MODEL=mistral

OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Berlin,DE
LATITUDE=52.520008
LONGITUDE=13.404954

STOCK_SYMBOLS=AAPL,MSFT,GOOGL,TSLA
NEWS_FEEDS=https://news.ycombinator.com/rss,https://www.heise.de/rss/heise-atom.xml

GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FOLDER=INBOX
CALENDAR_ICS_URL=
