# Bootstreep AI Agent – Konfiguration
# Kopiere diese Datei nach ~/ai-agent/.env und trage deine Werte ein

# Telegram Bot Token (von @BotFather auf Telegram)
TELEGRAM_BOT_TOKEN=DEIN_TELEGRAM_BOT_TOKEN_HIER

# Erlaubte Telegram-Chat-IDs (durch Komma getrennt)
# Leer lassen = alle Chats erlaubt (nur für Tests)
ALLOWED_CHAT_IDS=

# Server-Konfiguration
SERVER_NAME=Bootstreep
SERVER_IP=192.168.178.20
SSH_USER=admin
SSH_KEY_PATH=~/.ssh/id_ed25519

# Ollama (lokale KI) – optional
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b

# Daily Briefing – RSS/News-Quellen
NEWS_RSS_URLS=https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://feeds.bbci.co.uk/news/rss.xml,https://news.ycombinator.com/rss

# Finanzdaten (Aktien-Ticker, durch Komma getrennt)
STOCK_TICKERS=AAPL,MSFT,GOOGL,TSLA

# Wetter (OpenWeatherMap API Key + Stadt)
OPENWEATHER_API_KEY=
WEATHER_CITY=Berlin

# Email-Zusammenfassung (Gmail App Password)
# Siehe: https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Kalender (ics-URL, z.B. von Nextcloud)
CALENDAR_ICS_URL=


